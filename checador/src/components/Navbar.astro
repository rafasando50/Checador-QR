---
const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <div class="nav-container">
    <div class="nav-logo">
      <span class="logo-text">CHECADOR</span>
      <span class="logo-dot">.</span>
    </div>
    
    <div class="nav-links" id="nav-links">
      <a href="/" class={currentPath === "/" ? "active" : ""}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
        <span>Escáner</span>
      </a>
      <!-- Enlaces protegidos (se mostrarán vía JS) -->
      <div id="admin-links" class="admin-links-group" style="display: none;">
        <a href="/daily" class={currentPath === "/daily" ? "active" : ""}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Hoy</span>
        </a>
        <a href="/reports" class={currentPath === "/reports" ? "active" : ""}>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
          <span>Reportes</span>
        </a>
        <button id="btn-logout" class="btn-logout" title="Cerrar Sesión">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
      
      <!-- Enlace a login si no hay sesión -->
      <a href="/login" id="link-login" class={currentPath === "/login" ? "active" : ""} style="display: none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        <span>Admin</span>
      </a>
    </div>
  </div>
</nav>

<script>
  function updateNavbar() {
    const isAdmin = document.cookie.includes('checador_admin_session=true');
    const adminLinks = document.getElementById('admin-links');
    const loginLink = document.getElementById('link-login');
    
    if (isAdmin) {
      if (adminLinks) adminLinks.style.display = 'flex';
      if (loginLink) loginLink.style.display = 'none';
    } else {
      if (adminLinks) adminLinks.style.display = 'none';
      if (loginLink) loginLink.style.display = 'flex';
    }
  }

  // Ejecutar al cargar
  updateNavbar();

  // Listener para el botón de logout
  const logoutBtn = document.getElementById('btn-logout');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
      document.cookie = "checador_admin_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
      window.location.href = '/';
    });
  }
</script>

<style>
  .navbar {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.75rem 0;
    margin-bottom: 2rem;
  }

  .nav-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    font-weight: 900;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: #1e293b;
  }

  .logo-dot {
    color: #3b82f6;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .admin-links-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links a, .btn-logout {
    text-decoration: none;
    color: #64748b;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.6rem 1rem;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: inherit;
  }

  .nav-links a:hover, .btn-logout:hover {
    background: #f1f5f9;
    color: #1e293b;
  }

  .nav-links a.active {
    background: #eff6ff;
    color: #3b82f6;
  }

  .btn-logout {
    padding: 0.6rem;
    background: #3b82f6;
    color: white;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.15);
  }

  .btn-logout:hover {
    background: #2563eb;
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
  }

  @media (max-width: 640px) {
    .nav-container {
      flex-direction: column;
      gap: 1rem;
    }
    
    .nav-links {
      width: 100%;
      justify-content: center;
    }
    
    .nav-links a span {
      display: none;
    }
    
    .nav-links a {
      padding: 0.75rem;
    }
    
    .admin-links-group {
      gap: 0.25rem;
    }
  }
</style>

